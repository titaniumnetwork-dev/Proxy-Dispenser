{
	"private": true,
	"name": "dispenser",
	"workspaces": [
		"packages/**"
	],
	"devDependencies": {
		"@babel/preset-typescript": "^7.28.5",
		"@biomejs/biome": "2.3.14",
		"@types/bun": "latest",
		"@types/node": "^22.7.5",
		"drizzle-orm": "^0.45.1",
		"typescript": "^5.6.3"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"scripts": {
		"clear": "rm ./packages/bot/commands.json || true",
		"start": "cd packages/bot && npm run start",
		"dev": "npm run clear && npm run start",
		"fmt": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"typecheck": "tsgo -b",
		"typecheck:bot": "tsgo -b packages/bot",
		"typecheck:db": "tsgo -b packages/db",
		"posttest": "npm run lint",
		"db:generate": "cd packages/db && npm run db:generate",
		"db:migrate": "cd packages/db && npm run db:migrate"
	},
	"dependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260207.1",
		"drizzle-kit": "^0.31.8"
	}
}
