{
	"name": "dispenser",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "bun ./src/index.ts",
		"dev": "bun run clear && bun run start",
		"clear": "rm ./commands.json || true",
		"fmt": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"typecheck": "tsgo",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push",
		"db:studio": "drizzle-kit studio"
	},
	"dependencies": {
		"@types/node": "^25.3.5",
		"drizzle-orm": "^0.45.1",
		"seyfert": "^4.1.0",
		"try": "^1.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@types/bun": "1.3.12",
		"@libsql/client": "^0.17.0",
		"drizzle-kit": "^0.31.8",
		"@typescript/native-preview": "^7.0.0-dev.20260412.1",
		"typescript": "^6.0.2"
	},
	"patchedDependencies": {
		"try@1.0.3": "patches/try@1.0.3.patch"
	}
}
