{
	"name": "dispenser",
	"private": true,
	"type": "module",
	"scripts": {
		"start": "bun --env-file=.env ./src/index.ts",
		"dev": "bun run clear && bun run start",
		"clear": "rm ./commands.json || true",
		"fmt": "biome format --write",
		"lint": "biome lint --write",
		"check": "biome check --write",
		"typecheck": "tsgo",
		"db:generate": "bunx drizzle-kit generate",
		"db:migrate": "bun src/db/migrate.ts",
		"db:full": "bun run db:generate && bun run db:migrate"
	},
	"dependencies": {
		"@types/node": "^25.3.5",
		"drizzle-orm": "^0.45.1",
		"seyfert": "^4.1.0",
		"try": "^1.0.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@types/bun": "latest",
		"drizzle-kit": "^0.31.8",
		"@typescript/native-preview": "^7.0.0-dev.20260207.1",
		"typescript": "^5.6.3"
	},
	"patchedDependencies": {
		"try@1.0.3": "patches/try@1.0.3.patch"
	}
}
